# TrendMind Backend API — Environment Variables
# Copy this file to .env and fill in your actual values

# Server
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password_here
DB_NAME=trendmind

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_CACHE_DB=0
REDIS_BULLMQ_DB=1

# JWT — must be at least 32 characters
JWT_SECRET=your_very_secure_jwt_secret_minimum_32_characters_long
JWT_EXPIRY=7d

# OpenAI (required for AI Insights)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Trend Collector microservice
TREND_COLLECTOR_URL=http://localhost:8000
